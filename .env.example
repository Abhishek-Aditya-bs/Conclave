# CONCLAVE — environment config. Copy to .env (git-ignored); never commit a key.
# docker compose and ./scripts/up.sh read this automatically.

# Judge backend:  openai | anthropic | ollama
#   openai = any OpenAI-compatible endpoint (OpenAI, OpenRouter, Groq, …)
JUDGE_LLM_PROVIDER=openai

# Model id (blank = provider default). Default below is the cheapest serving judge.
JUDGE_LLM_MODEL=google/gemini-3.1-flash-lite

# Cloud key + endpoint. The default model above is served via OpenRouter.
#   OpenAI → https://api.openai.com/v1   ·   OpenRouter → https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Only if JUDGE_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Only if JUDGE_LLM_PROVIDER=ollama  (./scripts/up.sh local) — host Ollama endpoint
# OLLAMA_BASE_URL=http://host.docker.internal:11434
