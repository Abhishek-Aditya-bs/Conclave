# CONCLAVE — environment config.
#
# Copy to .env (git-ignored). docker compose reads this automatically.
#
# Two run modes (set by ./scripts/up.sh):
#   ./scripts/up.sh local   …  judge runs on YOUR host Ollama (Gemma). Ignores
#                              the cloud keys below. No .env strictly required.
#   ./scripts/up.sh serving …  judge runs on a cloud API key. Pick the provider
#                              and fill in the matching key below.

# ─────────────────────────── SERVING mode ───────────────────────────
# Which cloud provider to use for serving:  anthropic | openai
JUDGE_LLM_PROVIDER=anthropic

# Model id. Leave blank to use the per-provider default:
#   anthropic → claude-haiku-4-5-20251001
#   openai    → gpt-4o-mini
#   ollama    → gemma4:e4b   (local mode)
# JUDGE_LLM_MODEL=

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- OpenAI-compatible (covers OpenAI, Ollama Cloud, OpenRouter, Groq, …) ---
# One provider, many backends — just change the base URL + key + model.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
#   OpenAI       → https://api.openai.com/v1
#   Ollama Cloud → https://ollama.com/v1
#   OpenRouter   → https://openrouter.ai/api/v1
#   Groq         → https://api.groq.com/openai/v1

# ─────────────────────────── LOCAL mode ─────────────────────────────
# `./scripts/up.sh local` points the container at your host's Ollama and
# defaults the model to gemma4:e4b. Override either here if needed:
# JUDGE_LLM_MODEL=gemma4:e4b
# OLLAMA_BASE_URL=http://host.docker.internal:11434
#
# Make sure your host Ollama is running before sending events. If it only
# listens on 127.0.0.1 and the container can't reach it, start it with
# OLLAMA_HOST=0.0.0.0 so host.docker.internal resolves.
